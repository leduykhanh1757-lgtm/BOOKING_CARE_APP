<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Display CRUD</title>
    <style>
        table,
        th,
        td {
            border: 1px solid black;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 15px;
        }

        /* === Thêm CSS cho nút Edit === */
        .btn-edit {
            background-color: green;
            color: black;
            padding: 5px 10px;
            text-decoration: none;
            border: 1px solid black;
            cursor: pointer;
        }

        /* === Thêm CSS cho nút Delete === */
        .btn-delete {
            background-color: red;
            color: white;
            padding: 5px 10px;
            text-decoration: none;
            /* Xóa gạch chân của link */
            border: 1px solid black;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <h2>Danh sách người dùng</h2>

    <table style="width:100%">
        <tr>
            <th>Email</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Address</th>
            <th>Actions</th>
        </tr>

        <% for(let i=0; i < dataTable.length; i++) { %>
            <tr>
                <td>
                    <%= dataTable[i].email %>
                </td>
                <td>
                    <%= dataTable[i].firstName %>
                </td>
                <td>
                    <%= dataTable[i].lastName %>
                </td>
                <td>
                    <%= dataTable[i].address %>
                </td>
                <td>
                    <a href="/edit-crud?id=<%= dataTable[i].id %>" class="btn-edit">Edit</a>
                    <a href="/delete-crud?id=<%= dataTable[i].id %>" class="btn-delete">Delete</a>
                </td>
            </tr>
            <% } %>
    </table>

</body>

</html>